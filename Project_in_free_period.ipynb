# Subject 1: Telugu
if telugu<0 or telugu>100:
    print("You marks are invalid please enter the marks between 0 and 100")
else:
    if telugu>=35 and telugu<=100:
        if telugu >= 90: # Fixed: Now correctly includes 100
            print("The Grade for Telugu is: A+")
        elif telugu >= 75:
            print("The Grade for Telugu is: B")
        elif telugu >= 60:
            print("The Grade for Telugu is: C")
        else:
            print("The Grade for Telugu is: D")
    else:
        print("The Student Failed in the Telugu Subject")

